# Grant-Ready Business Plan Writer — Environment Configuration
# Copy this file to .env and fill in your values

# ============================================================
# LLM PROVIDER CONFIGURATION
# ============================================================
# Choose one: "ollama" (free, local) or "together" or "fireworks" or "replicate"
LLM_PROVIDER=ollama

# If using Ollama (default — runs locally for free)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# If using Together AI (https://together.ai)
TOGETHER_API_KEY=your_key_here
TOGETHER_MODEL=meta-llama/Meta-Llama-3.1-8B-Instruct-Turbo

# If using Fireworks AI (https://fireworks.ai)
FIREWORKS_API_KEY=your_key_here
FIREWORKS_MODEL=accounts/fireworks/models/llama-v3p1-8b-instruct

# ============================================================
# APP CONFIGURATION
# ============================================================
APP_TITLE=Grant-Ready Business Plan Writer
APP_SUBTITLE=Your AI-powered guide to a professional business plan
DEBUG=false
